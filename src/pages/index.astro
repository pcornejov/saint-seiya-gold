---
// index.astro
import Layout from '../layouts/Layout.astro';
import SaintsCodex from '../components/SaintsCodex.astro';
import SanctuaryPath from '../components/SanctuaryPath.astro';
import CosmosQuiz from '../components/CosmosQuiz.astro';
---

<Layout title="Saint Seiya: Caballeros de Oro | Códice y Doce Casas">
  <main>
    <!-- Hero Section -->
    <section id="hero-section">
      <div class="container hero-content">
        <div class="hero-text glass-panel">
          <h1 class="gold-text-gradient">El Poder del Cosmos Dorado</h1>
          <p class="hero-subtitle">Custodios del Santuario de Atena y dueños del Séptimo Sentido</p>
          <p class="hero-desc">
            Adéntrate en la senda celestial de los doce protectores zodiacales. Explora sus técnicas legendarias, asciende las doce escalinatas del Santuario y despierta el Cosmos divino que reside en tu interior.
          </p>
          <div class="hero-buttons">
            <a href="#codex-section" class="btn-gold" id="hero-btn-codex">Ver Caballeros</a>
            <a href="#sanctuary-section" class="btn-gold" id="hero-btn-sanctuary">Subir el Templo</a>
          </div>
        </div>
        <div class="hero-zodiac-wheel">
          <div class="zodiac-circle" id="zodiac-interactive-wheel">
            <div class="zodiac-center">
              <div class="gold-seal"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Codex Section -->
    <SaintsCodex />

    <!-- Sanctuary Path Section -->
    <SanctuaryPath />

    <!-- Quiz Section -->
    <CosmosQuiz />
  </main>
</Layout>

<style>
  /* Hero Section Styles */
  #hero-section {
    padding-top: calc(var(--header-height) + 50px);
    overflow: hidden;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-text h1 {
    font-size: 3.5rem;
    line-height: 1.15;
    letter-spacing: 2px;
    font-weight: 900;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--gold-light);
    letter-spacing: 1px;
    line-height: 1.4;
  }

  .hero-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .hero-buttons {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  /* Zodiac Wheel visual */
  .hero-zodiac-wheel {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .zodiac-circle {
    width: 360px;
    height: 360px;
    border-radius: 50%;
    border: 2px dashed rgba(255, 215, 0, 0.25);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    animation: rotateWheel 80s infinite linear;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.4), inset 0 0 30px rgba(255, 215, 0, 0.05);
  }

  .zodiac-circle::before {
    content: '';
    position: absolute;
    top: -10px;
    left: -10px;
    right: -10px;
    bottom: -10px;
    border-radius: 50%;
    border: 1px solid rgba(255, 215, 0, 0.15);
  }

  .zodiac-center {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px solid var(--gold-secondary);
    background: radial-gradient(circle, rgba(184, 134, 11, 0.3) 0%, rgba(2, 2, 8, 0.8) 100%);
    box-shadow: var(--gold-glow);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .gold-seal {
    width: 70px;
    height: 70px;
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23FFD700"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    opacity: 0.8;
  }

  @keyframes rotateWheel {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Responsive adjust */
  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }
    
    .hero-text {
      align-items: center;
    }
    
    .hero-buttons {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .hero-text h1 {
      font-size: 2.5rem;
    }
    
    .zodiac-circle {
      width: 280px;
      height: 280px;
    }
  }
</style>
