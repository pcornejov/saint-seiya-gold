---
// index.astro
import Layout from '../layouts/Layout.astro';
import SaintsCodex from '../components/SaintsCodex.astro';
import SanctuaryPath from '../components/SanctuaryPath.astro';
import CosmosQuiz from '../components/CosmosQuiz.astro';
---

<Layout title="Saint Seiya: Next Dimension | Códice y Guerra Santa del Siglo XVIII">
  <main id="main-content">
    <!-- Hero Section -->
    <section id="hero-section">
      <div class="container hero-content">
        <div class="hero-text glass-panel">
          <h1 class="gold-text-gradient">El Portal del Espacio-Tiempo</h1>
          <p class="hero-subtitle">Guerra Santa del Siglo XVIII y el Decimotercer Caballero de Oro</p>
          <p class="hero-desc">
            Viaja en el tiempo a través del portal de Chronos hacia el pasado mitológico del Santuario. Devela las identidades de los trece guardianes zodiacales, desafía la hipnosis de Ofiuco y despierta tu propio Cosmos sagrado.
          </p>
          <div class="hero-buttons">
            <a href="#codex-section" class="btn-gold" id="hero-btn-codex">Códice de Oro</a>
            <a href="#sanctuary-section" class="btn-gold" id="hero-btn-sanctuary">Subir el Santuario</a>
          </div>
        </div>
        <div class="hero-zodiac-wheel">
          <div class="zodiac-circle" id="zodiac-interactive-wheel">
            <div class="zodiac-center">
              <div class="gold-seal"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Codex Section -->
    <SaintsCodex />

    <!-- Sanctuary Path Section -->
    <SanctuaryPath />

    <!-- Quiz Section -->
    <CosmosQuiz />
  </main>
</Layout>

<style>
  /* Hero Section Styles */
  #hero-section {
    padding-top: calc(var(--header-height) + 50px);
    overflow: hidden;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-text h1 {
    font-size: 3.8rem;
    line-height: 1.15;
    letter-spacing: 2px;
    font-weight: 900;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--gold-light);
    letter-spacing: 1px;
    line-height: 1.4;
  }

  .hero-desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .hero-buttons {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  /* Zodiac Wheel visual */
  .hero-zodiac-wheel {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .hero-zodiac-wheel::before {
    content: '';
    position: absolute;
    width: 440px;
    height: 440px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(138, 43, 226, 0.28) 0%, rgba(220, 20, 60, 0.16) 45%, rgba(0, 0, 0, 0) 70%);
    filter: blur(20px);
    z-index: 0;
    animation: pulsePortal 6s infinite ease-in-out;
    pointer-events: none;
  }

  @keyframes pulsePortal {
    0%, 100% { transform: scale(0.92); opacity: 0.75; }
    50% { transform: scale(1.08); opacity: 1; }
  }

  .zodiac-circle {
    width: 380px;
    height: 380px;
    border-radius: 50%;
    border: 2px dashed rgba(255, 215, 0, 0.35);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    animation: rotateWheel 90s infinite linear;
    background: radial-gradient(circle, rgba(12, 6, 28, 0.7) 0%, rgba(4, 4, 12, 0.85) 100%);
    box-shadow: 
      0 0 50px rgba(138, 43, 226, 0.35),
      0 0 30px rgba(220, 20, 60, 0.2),
      inset 0 0 40px rgba(255, 215, 0, 0.08);
    z-index: 1;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .zodiac-circle::before {
    content: '';
    position: absolute;
    top: -15px;
    left: -15px;
    right: -15px;
    bottom: -15px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 215, 0, 0.25);
    box-shadow: 
      0 0 30px rgba(138, 43, 226, 0.35), 
      0 0 15px rgba(255, 215, 0, 0.15);
    animation: rotateWheel 60s infinite linear reverse;
    pointer-events: none;
  }

  .zodiac-circle::after {
    content: '';
    position: absolute;
    top: 15px;
    left: 15px;
    right: 15px;
    bottom: 15px;
    border-radius: 50%;
    border: 1.5px dashed rgba(220, 20, 60, 0.25);
    box-shadow: inset 0 0 20px rgba(220, 20, 60, 0.1);
    animation: rotateWheel 40s infinite linear reverse;
    pointer-events: none;
  }

  .zodiac-circle:hover {
    border-color: rgba(255, 215, 0, 0.65);
    box-shadow: 
      0 0 60px rgba(138, 43, 226, 0.5),
      0 0 40px rgba(220, 20, 60, 0.35),
      inset 0 0 50px rgba(255, 215, 0, 0.15);
    animation-duration: 45s; /* Speed up portal rotation on hover */
  }

  .zodiac-center {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 2px solid var(--gold-secondary);
    background: radial-gradient(circle, rgba(138, 43, 226, 0.45) 0%, rgba(220, 20, 60, 0.3) 50%, rgba(2, 2, 8, 0.95) 100%);
    box-shadow: 
      var(--gold-glow),
      0 0 20px rgba(138, 43, 226, 0.3);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 2;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .zodiac-center:hover {
    border-color: var(--gold-primary);
    box-shadow: 
      var(--gold-glow-strong),
      0 0 35px rgba(138, 43, 226, 0.5),
      0 0 25px rgba(220, 20, 60, 0.4);
    transform: scale(1.08);
  }

  .gold-seal {
    width: 80px;
    height: 80px;
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23FFD700"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    opacity: 0.8;
  }

  /* Responsive adjust */
  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }
    
    .hero-text {
      align-items: center;
    }
    
    .hero-buttons {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .hero-text h1 {
      font-size: 2.5rem;
    }
    
    .zodiac-circle {
      width: 280px;
      height: 280px;
    }
  }
</style>
