---
// SanctuaryPath.astro
import { goldSaints } from '../data/saintsData.js';

const templeLabels = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', '⛎', 'IX', 'X', 'XI', 'XII'];

// Coordinates climbing the mountain (X%, Y% relative to container)
// Incorporating Ophiuchus (Ofiuco - Odysseus) at index 8
const templeCoordinates = [
  { x: 12, y: 84 },  // I. Aries (Shion)
  { x: 23, y: 78 },  // II. Tauro (Ox)
  { x: 34, y: 71 },  // III. Géminis (Cain/Abel)
  { x: 44, y: 64 },  // IV. Cáncer (Deathtoll)
  { x: 55, y: 58 },  // V. Leo (Kaiser)
  { x: 67, y: 52 },  // VI. Virgo (Shijima)
  { x: 78, y: 46 },  // VII. Libra (Dohko)
  { x: 86, y: 38 },  // VIII. Escorpio (Ecarlate)
  { x: 83, y: 29 },  // ⛎. Ofiuco (Odysseus) -> Sits between Scorpio and Sagittarius!
  { x: 71, y: 24 },  // IX. Sagitario (Gestalt)
  { x: 58, y: 19 },  // X. Capricornio (Izo)
  { x: 45, y: 14 },  // XI. Acuario (Mystoria)
  { x: 32, y: 9 }    // XII. Piscis (Cardinale)
];
---

<section id="sanctuary-section">
  <div class="container">
    <h2 class="section-title gold-text-gradient">El Santuario del Siglo XVIII</h2>
    <p class="section-subtitle-text">Asciende las Doce Casas durante la Guerra Santa del pasado y atestigua el resurgir de la legendaria decimotercera casa.</p>
    
    <div class="sanctuary-path-wrapper">
      <!-- Mountain outline path -->
      <div class="mountain-path" id="mountain-interactive-path">
        <!-- SVG path representing the mountain climb with space-time glow -->
        <svg viewBox="0 0 800 600" class="path-svg" preserveAspectRatio="none">
          <defs>
            <filter id="gold-path-glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="5" result="blur" />
              <feComposite in="SourceGraphic" in2="blur" operator="over" />
            </filter>
            <linearGradient id="gold-path-grad" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#8B6508" />
              <stop offset="50%" stop-color="#FFD700" />
              <stop offset="100%" stop-color="#FFDF73" />
            </linearGradient>
          </defs>
          <!-- Outer thick glow path -->
          <path d="M 100 500 Q 200 450 300 400 T 500 300 T 700 200 T 500 100" fill="none" stroke="rgba(255, 215, 0, 0.25)" stroke-width="8" filter="url(#gold-path-glow)" />
          <!-- Inner core dashed path -->
          <path d="M 100 500 Q 200 450 300 400 T 500 300 T 700 200 T 500 100" fill="none" stroke="url(#gold-path-grad)" stroke-width="3" stroke-dasharray="12 6" />
        </svg>
        
        <!-- 13 Temple Nodes, generated statically by Astro! -->
        <div class="temples-nodes-container" id="temple-nodes-container" role="group" aria-label="Casas del Santuario">
          {goldSaints.map((saint, index) => {
            const coord = templeCoordinates[index] || { x: 50, y: 50 };
            const label = templeLabels[index];
            const isOphiuchus = saint.id === 'odysseus';
            return (
              <button 
                class={`temple-node ${isOphiuchus ? 'ophiuchus-node' : ''}`} 
                style={`left: ${coord.x}%; top: ${coord.y}%;`} 
                data-id={saint.id} 
                data-index={index}
                aria-label={`Templo ${label}. Casa de ${saint.sign}. Guardián: ${saint.name}`}
                aria-expanded="false"
                aria-controls="temple-drawer"
              >
                {label}
                <span class="temple-node-label" aria-hidden="true">{saint.sign}</span>
              </button>
            )
          })}
        </div>
      </div>

      <!-- Detail drawer for the current temple -->
      <div class="temple-info-drawer glass-panel hide" id="temple-drawer" tabindex="-1" aria-live="polite" style="outline: none;">
        <button class="close-drawer-btn" id="close-drawer" aria-label="Cerrar detalles del templo" aria-controls="temple-drawer">×</button>
        <div class="drawer-inner">
          <div class="drawer-header">
            <span class="temple-number" id="drawer-temple-number"></span>
            <h3 id="drawer-temple-name" class="gold-text-gradient"></h3>
          </div>
          <div class="drawer-body">
            <div class="drawer-visual">
              <div class="temple-pillar-svg" aria-hidden="true">🏛️</div>
              <div class="guardian-brief">
                <img id="drawer-guardian-img" src="" alt="Guardián" />
                <p>Guardián: <strong id="drawer-guardian-name"></strong></p>
              </div>
            </div>
            <p class="temple-lore" id="drawer-temple-lore"></p>
            <!-- inspect button container -->
            <div id="drawer-inspect-container"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-subtitle-text {
    text-align: center;
    max-width: 600px;
    margin: -2.5rem auto 3rem auto;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .sanctuary-path-wrapper {
    display: flex;
    position: relative;
    width: 100%;
    min-height: 620px;
    gap: 2rem;
    margin-top: 2rem;
  }

  /* Mountain path SVG container */
  .mountain-path {
    flex: 1;
    position: relative;
    height: 600px;
    background: 
      radial-gradient(circle at bottom right, rgba(184, 134, 11, 0.08) 0%, transparent 60%),
      radial-gradient(circle at top left, rgba(138, 43, 226, 0.25) 0%, transparent 50%),
      radial-gradient(circle at center, rgba(11, 19, 43, 0.4) 0%, rgba(2, 2, 8, 0.8) 100%);
    border: 1.5px solid rgba(255, 215, 0, 0.12);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 
      inset 0 0 30px rgba(0, 0, 0, 0.6),
      0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .path-svg {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
  }

  /* Nodes representing the temples */
  .temples-nodes-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .temple-node {
    position: absolute;
    width: 52px;
    height: 52px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(15, 15, 30, 0.9) 0%, rgba(5, 5, 15, 0.95) 100%);
    border: 2px solid var(--gold-secondary);
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--gold-light);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 
      0 4px 15px rgba(0, 0, 0, 0.6),
      inset 0 0 8px rgba(255, 215, 0, 0.1);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 3;
  }

  .temple-node::after {
    content: '';
    position: absolute;
    top: -6px;
    left: -6px;
    right: -6px;
    bottom: -6px;
    border-radius: 50%;
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .temple-node:hover,
  .temple-node:focus-visible {
    border-color: var(--gold-primary);
    color: #fff;
    box-shadow: 
      0 0 20px rgba(255, 215, 0, 0.4),
      0 6px 20px rgba(0, 0, 0, 0.5);
    transform: translate(-50%, -50%) scale(1.2);
    outline: none;
  }

  .temple-node:hover::after,
  .temple-node:focus-visible::after {
    border-color: rgba(255, 215, 0, 0.35);
    animation: rotateWheel 15s infinite linear;
  }

  /* Ophiuchus node has a unique celestial glow (red & purple) */
  .ophiuchus-node {
    border-color: var(--cosmic-crimson) !important;
    color: var(--cosmic-crimson-light) !important;
    box-shadow: 
      0 0 20px rgba(220, 20, 60, 0.6),
      0 0 10px rgba(138, 43, 226, 0.4),
      inset 0 0 10px rgba(220, 20, 60, 0.3);
    background: radial-gradient(circle, rgba(20, 5, 25, 0.95) 0%, rgba(5, 1, 10, 0.98) 100%) !important;
    z-index: 5;
  }

  /* Dual pulsing aura for emerging Ophiuchus */
  .ophiuchus-node::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 50%;
    border: 2px solid var(--cosmic-crimson);
    animation: ophiuchusPulse 2.4s infinite ease-out;
    pointer-events: none;
    z-index: -1;
  }

  .ophiuchus-node::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 50%;
    border: 2px solid var(--cosmic-purple-light);
    animation: ophiuchusPulse 2.4s infinite ease-out 1.2s;
    pointer-events: none;
    z-index: -1;
    transform: none; /* override general node::after transition properties */
  }

  @keyframes ophiuchusPulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
      box-shadow: 0 0 10px rgba(220, 20, 60, 0.4), 0 0 15px rgba(138, 43, 226, 0.2);
    }
    50% {
      opacity: 0.4;
      box-shadow: 0 0 20px rgba(220, 20, 60, 0.6), 0 0 25px rgba(138, 43, 226, 0.4);
    }
    100% {
      transform: scale(1.7);
      opacity: 0;
      box-shadow: 0 0 30px rgba(220, 20, 60, 0), 0 0 35px rgba(138, 43, 226, 0);
    }
  }

  .ophiuchus-node:hover {
    border-color: var(--cosmic-crimson-light) !important;
    color: #fff !important;
    box-shadow: 
      0 0 30px rgba(220, 20, 60, 0.95),
      0 0 20px rgba(138, 43, 226, 0.65),
      0 8px 25px rgba(0, 0, 0, 0.6) !important;
    transform: translate(-50%, -50%) scale(1.25);
  }

  .ophiuchus-node.active {
    background: linear-gradient(135deg, #600010 0%, var(--cosmic-crimson) 50%, var(--cosmic-crimson-light) 100%) !important;
    border-color: #fff !important;
    color: #fff !important;
    box-shadow: 
      0 0 35px rgba(220, 20, 60, 0.95),
      0 0 25px rgba(138, 43, 226, 0.7),
      0 8px 25px rgba(0, 0, 0, 0.7) !important;
    transform: translate(-50%, -50%) scale(1.3) !important;
  }

  .temple-node.active {
    background: var(--gold-cosmic);
    border-color: #fff;
    color: #020208;
    font-weight: 900;
    box-shadow: 
      0 0 25px rgba(255, 215, 0, 0.8),
      0 8px 25px rgba(0, 0, 0, 0.6);
    transform: translate(-50%, -50%) scale(1.25);
    text-shadow: none;
  }

  .temple-node-label {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-secondary);
    background: rgba(4, 4, 15, 0.85);
    backdrop-filter: blur(4px);
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 215, 0, 0.15);
    transition: all 0.3s ease;
    pointer-events: none;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
  }

  .temple-node:hover .temple-node-label {
    color: #fff;
    border-color: var(--gold-primary);
    box-shadow: 0 0 10px rgba(255, 215, 0, 0.2), 0 4px 10px rgba(0, 0, 0, 0.5);
  }

  .ophiuchus-node:hover .temple-node-label {
    border-color: #dc143c;
    box-shadow: 0 0 10px rgba(220, 20, 60, 0.2), 0 4px 10px rgba(0, 0, 0, 0.5);
  }

  .temple-node.active .temple-node-label {
    color: var(--gold-primary);
    border-color: var(--gold-primary);
    background: rgba(2, 2, 8, 0.95);
    box-shadow: var(--gold-glow), 0 4px 10px rgba(0, 0, 0, 0.6);
  }

  .ophiuchus-node.active .temple-node-label {
    color: #ff6688;
    border-color: #dc143c;
  }

  /* Detail Drawer */
  .temple-info-drawer {
    width: 360px;
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    position: relative;
    background: radial-gradient(circle at top right, rgba(20, 20, 45, 0.85) 0%, rgba(5, 5, 15, 0.9) 100%);
    border: 1.5px solid rgba(255, 215, 0, 0.25);
    border-radius: 16px;
    box-shadow: 
      0 15px 40px rgba(0, 0, 0, 0.8),
      inset 0 0 15px rgba(255, 215, 0, 0.05);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    animation: slideInRight 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .temple-info-drawer.ophiuchus-active {
    border-color: rgba(220, 20, 60, 0.6);
    box-shadow: 
      0 15px 40px rgba(0, 0, 0, 0.8),
      0 0 20px rgba(220, 20, 60, 0.25),
      inset 0 0 15px rgba(220, 20, 60, 0.1);
  }

  .close-drawer-btn {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    font-size: 1.8rem;
    color: var(--text-secondary);
    line-height: 1;
    transition: color 0.3s ease;
    cursor: pointer;
    background: none;
    border: none;
  }

  .close-drawer-btn:hover,
  .close-drawer-btn:focus-visible {
    color: var(--gold-primary);
    outline: none;
  }

  .drawer-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .drawer-header {
    border-bottom: 1px solid rgba(255, 215, 0, 0.15);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .temple-number {
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--gold-light);
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 0.2rem;
    display: block;
  }

  .drawer-header h3 {
    font-size: 1.4rem;
    letter-spacing: 1px;
  }

  .drawer-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    color: var(--text-secondary);
  }

  .drawer-visual {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 215, 0, 0.05);
    border-radius: 8px;
    padding: 0.8rem;
  }

  .temple-pillar-svg {
    font-size: 2.2rem;
    line-height: 1;
  }

  .guardian-brief {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .guardian-brief img {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    border: 2px solid var(--gold-secondary);
    object-fit: cover;
    object-position: top center;
    background: var(--bg-space-fallback);
    box-shadow: var(--gold-glow);
    transition: all 0.3s ease;
  }

  .guardian-brief:hover img {
    border-color: var(--gold-primary);
    transform: scale(1.08);
  }

  .guardian-brief p {
    font-size: 0.8rem;
  }

  .guardian-brief strong {
    font-family: var(--font-serif);
    color: var(--gold-primary);
    font-size: 0.9rem;
  }

  .temple-lore {
    font-size: 0.92rem;
    line-height: 1.6;
  }

  :global(.drawer-body .btn-gold) {
    margin-top: 1rem;
    width: 100%;
  }

  /* Ophiuchus active Drawer styling */
  .temple-info-drawer.ophiuchus-active {
    border-color: var(--cosmic-crimson);
    background: radial-gradient(circle at top right, rgba(42, 10, 50, 0.92) 0%, rgba(8, 2, 20, 0.96) 60%, rgba(32, 5, 12, 0.94) 100%);
    box-shadow: 
      0 20px 50px rgba(0, 0, 0, 0.9),
      0 0 25px rgba(220, 20, 60, 0.4),
      inset 0 0 20px rgba(138, 43, 226, 0.2);
  }

  .temple-info-drawer.ophiuchus-active .temple-number {
    color: var(--cosmic-crimson-light);
    text-shadow: 0 0 8px rgba(220, 20, 60, 0.4);
  }

  .temple-info-drawer.ophiuchus-active .gold-text-gradient {
    background: linear-gradient(135deg, #ff99aa 0%, var(--cosmic-crimson-light) 50%, var(--cosmic-crimson) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: var(--cosmic-crimson-light);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5), 0 0 10px rgba(220, 20, 60, 0.3);
  }

  .temple-info-drawer.ophiuchus-active .guardian-brief img {
    border-color: var(--cosmic-crimson);
    box-shadow: 0 0 12px rgba(220, 20, 60, 0.5);
  }

  .temple-info-drawer.ophiuchus-active .guardian-brief strong {
    color: var(--cosmic-crimson-light);
  }

  .temple-info-drawer.ophiuchus-active #close-drawer:hover {
    color: var(--cosmic-crimson-light);
  }

  @keyframes pulseNode {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(50px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (max-width: 860px) {
    .sanctuary-path-wrapper {
      flex-direction: column;
    }
    
    .mountain-path {
      height: 450px;
    }
    
    .temple-info-drawer {
      width: 100%;
      animation: fadeIn 0.4s ease-out forwards;
    }
  }

  @media (max-width: 640px) {
    .temple-node {
      width: 38px;
      height: 38px;
      font-size: 0.8rem;
    }
    .temple-node-label {
      top: 44px;
      font-size: 0.65rem;
      padding: 0.15rem 0.35rem;
    }
    .ophiuchus-node:hover .temple-node-label {
      box-shadow: 0 0 10px rgba(220, 20, 60, 0.2);
    }
  }
</style>

<script>
  import { goldSaints } from '../data/saintsData.js';

  const templeLabels = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'Ofiuco', 'IX', 'X', 'XI', 'XII'];

  const templeLores = [
    "La primera casa del Santuario. Aquí, el sabio Shion recibe a los viajeros temporales Shun y Tenma de Pegaso, reparando sus dañadas armaduras de bronce antes de hacer frente a los espectros invasores.",
    "El inquebrantable Ox de Tauro defiende el paso. Con su inmenso Gran Cuerno repele a los espectros rasos y libra un salvaje combate de honor físico contra la ferocidad de Suikyō de Garuda.",
    "La casa laberíntica de la esquizofrenia. Caín de Géminis lucha por el honor de Athena, mientras que su gemelo Abel intenta traicionarla. Ambos intercambian el control corporal frente a Shun y Tenma.",
    "El excéntrico Deathtoll fabrica ataúdes para canalizar las almas rebeldes. Mantiene un combate tragicómico y cruel contra los invasores utilizando su ataúd mitológico 'Omertà' en la entrada del Yomotsu.",
    "Kaiser de Leo defiende su casa con la ayuda de sus feroces leones gigantes de oro, Goldie y Blondie. Pone a prueba el espíritu y lealtad de Shun antes de concederle el derecho de paso.",
    "Shijima, 'el hombre silencioso', resguarda la Casa de Virgo. Crea el Laberinto de los Dioses y sella el templo con las Cuatro Puertas de Buda para salvaguardar a la bebé Athena de la traición del Patriarca.",
    "El joven Dohko de Libra lucha contra su destino en la séptima casa. Se enfrenta a su querido amigo de la infancia Suikyō, llorando su trágico sacrificio de sangre antes de aliarse con la causa rebelde.",
    "Écarlate de Escorpio, dotado de invisibilidad tras la picadura de un escorpión cristalino, lucha contra Shiryū de Dragón. Le perdona la vida tras comprobar su convicción al ver la garra del dragón celestial.",
    "El Templo de Ofiuco emerge desde el inframundo, rompiendo los cimientos del Santuario. Odysseus de Ofiuco resucita y sume a todos los caballeros en una hipnoterapia divina para sanar y juzgar su lealtad.",
    "Gestalt de Sagitario dispara la Flecha de Quirón. Hyōga de Cisne le demuestra que sus piernas de centauro son una ilusión física nacida de la culpa y el dolor por la pérdida de su amada yegua Tanya.",
    "Izō de Capricornio, el implacable 'cortador de demonios', pone a prueba el honor de Hyōga con cortes brutales de su espada Excalibur, probando si está dispuesto a morir por defender a Athena.",
    "Mystoria de Acuario custodia la undécima casa. Pone a prueba la maestría glacial de Hyōga en un duelo épico de Ejecuciones de Aurora, confiándole finalmente el resguardo de la diosa del futuro.",
    "Cardinale de Piscis bloquea el camino final sembrando un letal jardín de rosas rojas y blancas. Aunque inicialmente sirve al traidor, se redime sacrificando su vida para proteger a Shijima y Athena."
  ];

  document.addEventListener('DOMContentLoaded', () => {
    const templeNodes = document.querySelectorAll('.temple-node');
    const drawer = document.getElementById('temple-drawer');
    const closeBtn = document.getElementById('close-drawer');
    
    const drawerNumber = document.getElementById('drawer-temple-number');
    const drawerName = document.getElementById('drawer-temple-name');
    const drawerImg = document.getElementById('drawer-guardian-img') as HTMLImageElement;
    const drawerGuardianName = document.getElementById('drawer-guardian-name');
    const drawerLore = document.getElementById('drawer-temple-lore');
    const inspectContainer = document.getElementById('drawer-inspect-container');

    let lastActiveNode: HTMLButtonElement | null = null;

    templeNodes.forEach(node => {
      node.addEventListener('click', () => {
        const indexStr = node.getAttribute('data-index');
        if (indexStr !== null) {
          selectTemple(parseInt(indexStr));
        }
      });
    });

    if (closeBtn && drawer) {
      closeBtn.addEventListener('click', () => {
        drawer.classList.add('hide');
        drawer.classList.remove('ophiuchus-active');
        templeNodes.forEach(n => {
          n.classList.remove('active');
          n.setAttribute('aria-expanded', 'false');
        });
        if (lastActiveNode) {
          lastActiveNode.focus();
        }
      });
    }

    function selectTemple(index: number) {
      templeNodes.forEach((node, idx) => {
        if (idx === index) {
          node.classList.add('active');
          node.setAttribute('aria-expanded', 'true');
          lastActiveNode = node as HTMLButtonElement;
        } else {
          node.classList.remove('active');
          node.setAttribute('aria-expanded', 'false');
        }
      });

      const saint = goldSaints[index];
      if (!saint) return;

      if (drawer) {
        drawer.classList.remove('hide');
        if (saint.id === 'odysseus') {
          drawer.classList.add('ophiuchus-active');
        } else {
          drawer.classList.remove('ophiuchus-active');
        }
      }

      const label = templeLabels[index];
      if (drawerNumber) {
        drawerNumber.textContent = label === 'Ofiuco' ? 'Templo Legendario' : `Templo ${label}`;
      }
      if (drawerName) drawerName.textContent = saint.temple;
      if (drawerImg) {
        drawerImg.src = saint.image;
        drawerImg.alt = `Retrato del Caballero de Oro ${saint.name}`;
      }
      if (drawerGuardianName) {
        drawerGuardianName.textContent = saint.name.split(' de ')[0];
      }
      if (drawerLore) {
        drawerLore.textContent = templeLores[index] || "Custodiado por un Caballero de Oro del siglo XVIII.";
      }

      if (inspectContainer) {
        inspectContainer.innerHTML = '';
        const inspectBtn = document.createElement('button');
        inspectBtn.className = 'btn-gold';
        inspectBtn.textContent = 'Ver en el Códice';
        inspectBtn.addEventListener('click', () => {
          // Scroll to codex section
          const codexSec = document.getElementById('codex-section');
          if (codexSec) {
            codexSec.scrollIntoView({ behavior: 'smooth' });
          }

          // Hydrate selected Saint in Codex
          setTimeout(() => {
            if ((window as any).selectSaintInCodex) {
              (window as any).selectSaintInCodex(saint.id);
            }
          }, 500);
        });
        inspectContainer.appendChild(inspectBtn);
      }

      // Mobile UX: Scroll to the details drawer on mobile devices
      if (window.innerWidth <= 860 && drawer) {
        drawer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      // Accessibility: Focus the drawer so it's announced to screen readers
      if (drawer) {
        setTimeout(() => {
          drawer.focus();
        }, 150);
      }
    }

    // Close drawer on Escape key press (a11y)
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && drawer && !drawer.classList.contains('hide')) {
        closeBtn?.click();
      }
    });
  });
</script>
