---
// CanvasBackground.astro
---

<canvas id="space-canvas"></canvas>
<div class="cosmic-nebula"></div>

<style>
  #space-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -2;
    background: #020108; /* Deep cosmic dark */
    pointer-events: none;
  }

  .cosmic-nebula {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    background: 
      radial-gradient(circle at 30% 30%, rgba(27, 10, 42, 0.45) 0%, transparent 60%),
      radial-gradient(circle at 70% 70%, rgba(139, 10, 20, 0.2) 0%, transparent 60%),
      radial-gradient(circle at center, rgba(184, 134, 11, 0.05) 0%, transparent 70%);
    mix-blend-mode: screen;
    pointer-events: none;
    opacity: 0.8;
  }
</style>

<script>
  // Space-Time Vortex Particle Engine (Portal of Chronos)
  const canvas = document.getElementById('space-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      let width = canvas.width = window.innerWidth;
      let height = canvas.height = window.innerHeight;
      
      const particleCount = 180;
      const particles: SpaceTimeParticle[] = [];
      const threadCount = 3;
      const threads: RedThread[] = [];

      class SpaceTimeParticle {
        angle: number;
        radius: number;
        speed: number;
        size: number;
        color: string;
        opacity: number;
        z: number;
        colorType: 'purple' | 'red' | 'gold' | 'white';

        constructor(isInitial = false) {
          this.angle = Math.random() * Math.PI * 2;
          this.radius = isInitial ? Math.random() * (Math.max(width, height) * 0.7) : Math.max(width, height) * 0.7;
          this.speed = Math.random() * 1.5 + 0.5;
          this.size = Math.random() * 1.8 + 0.4;
          this.z = Math.random() * 200;
          this.opacity = Math.random() * 0.5 + 0.3;
          
          const roll = Math.random();
          if (roll > 0.85) {
            this.color = '255, 215, 0'; // Gold Cosmos
            this.colorType = 'gold';
          } else if (roll > 0.6) {
            this.color = '220, 20, 60'; // Crimson (Next Dimension red)
            this.colorType = 'red';
          } else if (roll > 0.25) {
            this.color = '138, 43, 226'; // Deep Purple (Chronos space-time)
            this.colorType = 'purple';
          } else {
            this.color = '255, 255, 255'; // Celestial starlight
            this.colorType = 'white';
          }
        }

        update() {
          // Particles spiral inwards towards the center (representing the time vortex)
          this.angle += (0.003 + (150 / (this.radius + 50)) * 0.0002) * this.speed;
          this.radius -= (0.8 + (this.radius / 300)) * this.speed;
          
          // Fade in near the edge, fade out near the center
          const maxRadius = Math.max(width, height) * 0.7;
          if (this.radius < 40) {
            // Reset to outer rim
            this.radius = maxRadius;
            this.angle = Math.random() * Math.PI * 2;
            this.opacity = 0;
          } else if (this.radius > maxRadius - 100) {
            this.opacity = Math.min(0.8, (maxRadius - this.radius) / 100);
          } else {
            this.opacity = Math.min(0.8, (this.radius - 40) / 150);
          }
        }

        draw() {
          if (!ctx) return;
          
          const x = width / 2 + Math.cos(this.angle) * this.radius;
          const y = height / 2 + Math.sin(this.angle) * this.radius;
          
          ctx.beginPath();
          ctx.arc(x, y, this.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${this.color}, ${this.opacity})`;
          
          if (this.colorType === 'gold') {
            ctx.shadowBlur = this.size * 3;
            ctx.shadowColor = 'rgba(255, 215, 0, 0.8)';
          } else if (this.colorType === 'red') {
            ctx.shadowBlur = this.size * 2;
            ctx.shadowColor = 'rgba(220, 20, 60, 0.8)';
          }
          
          ctx.fill();
          ctx.shadowBlur = 0; // Reset
        }
      }

      // Red Threads of Fate winding through the portal
      class RedThread {
        points: { x: number; y: number }[] = [];
        offset: number;
        speed: number;

        constructor(index: number) {
          this.offset = index * (Math.PI * 2 / threadCount);
          this.speed = 0.008;
        }

        update() {
          this.offset += this.speed;
          this.points = [];
          
          const maxRadius = Math.max(width, height) * 0.7;
          // Build a spiral path
          for (let r = maxRadius; r > 30; r -= 15) {
            const a = (r * 0.008) + this.offset;
            const x = width / 2 + Math.cos(a) * r;
            const y = height / 2 + Math.sin(a) * r;
            this.points.push({ x, y });
          }
        }

        draw() {
          if (!ctx || this.points.length < 2) return;
          
          ctx.beginPath();
          ctx.moveTo(this.points[0].x, this.points[0].y);
          for (let i = 1; i < this.points.length; i++) {
            ctx.lineTo(this.points[i].x, this.points[i].y);
          }
          
          const gradient = ctx.createRadialGradient(
            width / 2, height / 2, 50,
            width / 2, height / 2, Math.max(width, height) * 0.5
          );
          gradient.addColorStop(0, 'rgba(220, 20, 60, 0)');
          gradient.addColorStop(0.2, 'rgba(220, 20, 60, 0.45)');
          gradient.addColorStop(0.8, 'rgba(220, 20, 60, 0.15)');
          gradient.addColorStop(1, 'rgba(220, 20, 60, 0)');
          
          ctx.strokeStyle = gradient;
          ctx.lineWidth = 1.8;
          ctx.stroke();
        }
      }

      // Initialize
      for (let i = 0; i < particleCount; i++) {
        particles.push(new SpaceTimeParticle(true));
      }
      for (let i = 0; i < threadCount; i++) {
        threads.push(new RedThread(i));
      }

      // Resize
      window.addEventListener('resize', () => {
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;
      });

      // Loop
      function animate() {
        if (!ctx) return;
        ctx.clearRect(0, 0, width, height);

        // Draw center space-time singularity (gradient)
        const singularity = ctx.createRadialGradient(
          width / 2, height / 2, 0,
          width / 2, height / 2, 100
        );
        singularity.addColorStop(0, '#000000');
        singularity.addColorStop(0.4, 'rgba(10, 2, 20, 0.8)');
        singularity.addColorStop(1, 'rgba(2, 1, 8, 0)');
        
        ctx.fillStyle = singularity;
        ctx.beginPath();
        ctx.arc(width / 2, height / 2, 100, 0, Math.PI * 2);
        ctx.fill();

        // Update & Draw Threads
        threads.forEach(thread => {
          thread.update();
          thread.draw();
        });

        // Update & Draw Particles
        particles.forEach(p => {
          p.update();
          p.draw();
        });

        requestAnimationFrame(animate);
      }

      animate();
    }
  }
</script>
