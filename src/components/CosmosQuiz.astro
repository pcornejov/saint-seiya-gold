---
// CosmosQuiz.astro
---

<section id="quiz-section">
  <div class="container">
    <h2 class="section-title gold-text-gradient">Alineación de Cosmos</h2>
    
    <div class="quiz-box glass-panel" id="quiz-container">
      <!-- Start Screen -->
      <div class="quiz-screen active" id="quiz-start-screen">
        <div class="quiz-ritual-circle">🪐</div>
        <h3>¿Qué Caballero de Oro del Siglo XVIII resuena en tu Cosmos?</h3>
        <p>El portal de Chronos ha distorsionado el espacio-tiempo. Responde con la verdad moral de tu espíritu y descubre a qué guardián de la Guerra Santa del pasado estás alineado dimensionalmente.</p>
        <button class="btn-gold" id="start-quiz-btn">Comenzar Ritual</button>
      </div>

      <!-- Question Screen -->
      <div class="quiz-screen" id="quiz-question-screen">
        <div class="quiz-progress-bar" id="quiz-progress-bar-container" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="Progreso de la prueba">
          <div class="progress-fill" id="quiz-progress-fill"></div>
        </div>
        <span class="quiz-counter" id="quiz-counter">Pregunta 1 de 5</span>
        <h3 class="quiz-question" id="quiz-question-text" tabindex="-1" style="outline: none;">¿Cómo reaccionas ante una injusticia extrema?</h3>
        <div class="quiz-options" id="quiz-options-container" role="radiogroup" aria-label="Opciones de respuesta">
          <!-- Options rendered dynamically -->
        </div>
      </div>

      <!-- Results Screen -->
      <div class="quiz-screen" id="quiz-results-screen" tabindex="-1" style="outline: none;">
        <div class="result-celebration">✨ TU ALINEACIÓN CÓSMICA DIMENSIONAL ✨</div>
        <div class="result-card-glow"></div>
        <div class="result-card" id="result-shareable-card">
          <!-- Collectible Card Details -->
          <div class="card-corner top-left"></div>
          <div class="card-corner top-right"></div>
          <div class="card-corner bottom-left"></div>
          <div class="card-corner bottom-right"></div>
          
          <div class="result-card-inner">
            <div class="result-header">
              <span class="result-badge">Caballero de Oro (Siglo XVIII)</span>
              <h3 id="result-saint-name" class="gold-text-gradient"></h3>
              <p id="result-saint-title"></p>
            </div>
            <div class="result-body">
              <img id="result-saint-portrait" src="" alt="Retrato del Caballero Dorado alineado" />
              <div class="result-text-block">
                <p id="result-saint-desc"></p>
                <div class="result-traits">
                  <span class="trait-tag" id="trait-1"></span>
                  <span class="trait-tag" id="trait-2"></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="result-actions">
          <button class="btn-gold" id="view-in-codex-btn">Ver en el Códice</button>
          <button class="btn-gold" id="restart-quiz-btn" style="background: rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.2); text-shadow: none;">Volver a Intentar</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .quiz-box {
    max-width: 700px;
    width: 100%;
    margin: 0 auto;
    min-height: 420px;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .quiz-screen {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    animation: fadeIn 0.4s ease-out forwards;
  }

  .quiz-screen.active {
    display: flex;
  }

  /* Start Screen */
  .quiz-ritual-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px dashed rgba(255, 215, 0, 0.4);
    background: radial-gradient(circle, rgba(184, 134, 11, 0.2) 0%, rgba(2, 2, 8, 0.6) 100%);
    box-shadow: var(--gold-glow);
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 3.5rem;
    margin: 0 auto 2rem auto;
    animation: float 4s ease-in-out infinite, rotateWheel 60s infinite linear;
  }

  .quiz-screen h3 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--gold-light);
    margin-bottom: 1.2rem;
    letter-spacing: 1px;
  }

  .quiz-screen p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 550px;
  }

  /* Progress bar */
  .quiz-progress-bar {
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--gold-cosmic);
    box-shadow: var(--gold-glow);
    transition: width 0.4s ease;
  }

  .quiz-counter {
    font-family: var(--font-serif);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gold-secondary);
    margin-bottom: 0.5rem;
  }

  /* Question view */
  .quiz-question {
    margin-bottom: 2rem;
    font-size: 1.5rem !important;
    color: var(--text-primary) !important;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 500px;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .quiz-question.fade-out,
  .quiz-options.fade-out {
    opacity: 0;
    transform: translateY(-8px);
  }

  :global(.option-btn) {
    background: rgba(15, 15, 35, 0.5);
    border: 1.5px solid rgba(255, 215, 0, 0.15);
    border-radius: 10px;
    padding: 1.2rem 1.8rem;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 500;
    line-height: 1.5;
    text-align: left;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    width: 100%;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  }

  :global(.option-btn::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 4px;
    background: var(--gold-primary);
    transform: scaleY(0);
    transition: transform 0.3s ease;
  }

  :global(.option-btn:hover),
  :global(.option-btn:focus-visible) {
    background: rgba(255, 215, 0, 0.04);
    border-color: rgba(255, 215, 0, 0.4);
    color: #fff;
    transform: translateX(4px);
    box-shadow: 
      0 6px 15px rgba(0, 0, 0, 0.3),
      0 0 15px rgba(255, 215, 0, 0.05);
    outline: none;
  }

  :global(.option-btn:hover::before),
  :global(.option-btn:focus-visible::before) {
    transform: scaleY(1);
  }

  :global(.option-btn:active) {
    transform: translateY(0);
  }

  :global(.option-btn.selected) {
    background: radial-gradient(circle at left, rgba(184, 134, 11, 0.2) 0%, rgba(10, 10, 25, 0.8) 100%);
    border-color: var(--gold-primary);
    color: var(--gold-primary);
    font-weight: 700;
    box-shadow: var(--gold-glow), 0 6px 20px rgba(0, 0, 0, 0.4);
    transform: scale(1.01);
  }

  :global(.option-btn.selected::before) {
    transform: scaleY(1);
    background: var(--gold-light);
    box-shadow: var(--gold-glow);
  }

  /* Results Screen & Shareable Card */
  .result-celebration {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    letter-spacing: 4px;
    color: var(--gold-primary);
    margin-bottom: 1.5rem;
    text-shadow: var(--gold-glow);
  }

  .result-card {
    width: 100%;
    max-width: 480px;
    background: radial-gradient(circle at top right, rgba(32, 12, 54, 0.95) 0%, rgba(6, 3, 16, 0.98) 50%, rgba(48, 6, 22, 0.95) 100%);
    border: 2px solid rgba(255, 215, 0, 0.7);
    border-radius: 22px;
    box-shadow: 
      0 25px 60px rgba(0, 0, 0, 0.85),
      0 0 35px rgba(255, 215, 0, 0.3),
      0 0 45px rgba(138, 43, 226, 0.25),
      inset 0 0 20px rgba(255, 255, 255, 0.04);
    padding: 2.5rem 2.2rem;
    margin-bottom: 2.5rem;
    position: relative;
    overflow: hidden;
    text-align: left;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 1;
  }

  /* Holographic Foil overlay */
  .result-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255, 255, 255, 0.02) 20%,
      rgba(138, 43, 226, 0.16) 35%,
      rgba(220, 20, 60, 0.18) 45%,
      rgba(255, 215, 0, 0.16) 55%,
      rgba(0, 255, 255, 0.12) 65%,
      rgba(255, 255, 255, 0.02) 80%,
      transparent 100%
    );
    background-size: 250% 250%;
    background-position: 0% 50%;
    mix-blend-mode: color-dodge;
    opacity: 0.85;
    pointer-events: none;
    z-index: 4;
    animation: holoShimmer 9s infinite linear alternate;
    transition: all 0.5s ease;
  }

  @keyframes holoShimmer {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .result-card:hover {
    transform: translateY(-8px) rotate(1.5deg) scale(1.02);
    border-color: var(--gold-light);
    box-shadow: 
      0 35px 80px rgba(0, 0, 0, 0.9),
      0 0 50px rgba(255, 215, 0, 0.55),
      0 0 40px rgba(138, 43, 226, 0.45),
      0 0 30px rgba(220, 20, 60, 0.35);
  }

  .result-card:hover::before {
    opacity: 1;
    animation-duration: 4.5s;
  }

  /* Card corner brackets */
  .card-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid var(--gold-secondary);
    pointer-events: none;
    z-index: 5;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .top-left {
    top: 12px;
    left: 12px;
    border-right: none;
    border-bottom: none;
  }

  .top-right {
    top: 12px;
    right: 12px;
    border-left: none;
    border-bottom: none;
  }

  .bottom-left {
    bottom: 12px;
    left: 12px;
    border-right: none;
    border-top: none;
  }

  .bottom-right {
    bottom: 12px;
    right: 12px;
    border-left: none;
    border-top: none;
  }

  .result-card:hover .card-corner {
    border-color: var(--gold-primary);
    width: 18px;
    height: 18px;
    filter: drop-shadow(0 0 3px rgba(255, 215, 0, 0.5));
  }

  .result-header {
    border-bottom: 1px solid rgba(255, 215, 0, 0.15);
    padding-bottom: 1rem;
    margin-bottom: 1.2rem;
    position: relative;
    z-index: 2;
  }

  .result-badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--gold-light);
    letter-spacing: 2px;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 0.4rem;
    background: rgba(138, 43, 226, 0.25);
    border: 1px solid rgba(138, 43, 226, 0.45);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-shadow: 0 0 5px rgba(138, 43, 226, 0.5);
  }

  .result-header h3 {
    font-size: 1.8rem;
    margin-bottom: 0.1rem;
    letter-spacing: 1px;
  }

  #result-saint-title {
    font-size: 0.85rem;
    font-family: var(--font-serif);
    color: var(--text-secondary);
  }

  .result-body {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  #result-saint-portrait {
    width: 120px;
    height: 160px;
    object-fit: cover;
    object-position: top center;
    border-radius: 10px;
    border: 2px solid var(--gold-secondary);
    background: var(--bg-space-fallback);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
    flex-shrink: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .result-card:hover #result-saint-portrait {
    border-color: var(--gold-primary);
    transform: scale(1.05);
    box-shadow: var(--gold-glow), 0 6px 20px rgba(0, 0, 0, 0.6);
  }

  .result-text-block {
    flex-grow: 1;
  }

  #result-saint-desc {
    font-size: 0.86rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 1rem;
    max-height: 95px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .result-traits {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .trait-tag {
    background: rgba(255, 215, 0, 0.08);
    border: 1px solid rgba(255, 215, 0, 0.25);
    color: var(--gold-light);
    font-size: 0.72rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .trait-tag:hover {
    background: rgba(255, 215, 0, 0.18);
    border-color: var(--gold-primary);
    box-shadow: var(--gold-glow);
    color: #fff;
  }

  .result-actions {
    display: flex;
    gap: 1rem;
    z-index: 2;
  }

  @media (max-width: 580px) {
    .result-body {
      flex-direction: column;
      text-align: center;
    }
    
    #result-saint-portrait {
      width: 100px;
      height: 130px;
    }
    
    .result-traits {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .result-actions {
      flex-direction: column;
      width: 100%;
    }
    .result-actions .btn-gold {
      width: 100%;
    }
  }
</style>

<script>
  import { goldSaints } from '../data/saintsData.js';

  const quizQuestions = [
    {
      question: "Ante una distorsión en el espacio-tiempo que amenaza el futuro de Athena, ¿cuál es tu reacción?",
      options: [
        { text: "Cruzar el portal de inmediato sin medir consecuencias para luchar en el pasado.", weights: { dohko: 3, shion: 2, kaiser: 1 } },
        { text: "Esperar en mi templo resguardando mi época y cumpliendo mi deber absoluto.", weights: { ox: 3, izo: 3, mystoria: 2 } },
        { text: "Analizar la anomalía astral con mi mente espiritual e intentar meditar en ella.", weights: { shijima: 3, odysseus: 2, cain: 1 } },
        { text: "Aprovechar la confusión temporal para negociar o jugar con ambas facciones.", weights: { deathtoll: 3, cardinale: 2 } }
      ]
    },
    {
      question: "Si tu mentor o tu mejor amigo regresa vistiendo el manto del enemigo (los espectros), ¿cómo procedes?",
      options: [
        { text: "Lo enfrento a regañadientes, llorando su traición pero cumpliendo con mi orden.", weights: { dohko: 3, shion: 3 } },
        { text: "Bloqueo su paso con la intención firme de ejecutarlo con golpes absolutos.", weights: { ox: 3, izo: 3, mystoria: 2 } },
        { text: "Intento salvar su espíritu y juzgar sus intenciones reales con mi cosmos.", weights: { odysseus: 3, shijima: 2 } },
        { text: "Le tiendo una trampa mortal en mi templo utilizando ataúdes o ilusiones.", weights: { deathtoll: 3, cain: 2, cardinale: 2 } }
      ]
    },
    {
      question: "Si padecieras una extraña condición física o una ilusión psíquica que altere tu ser, ¿cómo actuarías?",
      options: [
        { text: "Usaría mi invisibilidad y picaduras de veneno para atacar sigilosamente.", weights: { ecarlate: 3 } },
        { text: "Me aferraría a la ilusión trágica por amor al pasado, aunque me ciegue.", weights: { gestalt: 3 } },
        { text: "Lucharía internamente para mantener a raya mi mitad maligna devoradora.", weights: { cain: 3 } },
        { text: "Buscaría la ayuda de un dios sanador a quien le deba mi vida.", weights: { odysseus: 3, ecarlate: 2, gestalt: 2 } }
      ]
    },
    {
      question: "¿Cuál es tu postura ante el regreso de Odysseus de Ofiuco y su rebelión divina?",
      options: [
        { text: "Le debo la vida y mi salud; me debato entre mi deber y mi enorme deuda.", weights: { ecarlate: 3, gestalt: 3, cardinale: 2 } },
        { text: "Mi lealtad a Athena es inmutable; desenvaino mi espada para combatirlo.", weights: { izo: 3, ox: 2, kaiser: 2 } },
        { text: "Adormezco mis dudas y me entrego a su hipnoterapia divina para descansar.", weights: { odysseus: 3, mystoria: 2 } },
        { text: "Intento descifrar su cosmos espiritual antes de tomar partido a la fuerza.", weights: { shijima: 3, shion: 2, cain: 2 } }
      ]
    },
    {
      question: "¿Cuál es tu estilo de combate o técnica espiritual predilecta?",
      options: [
        { text: "Un filo invisible en mi brazo capaz de rebanar el espacio mismo.", weights: { izo: 3 } },
        { text: "Ráfagas glaciales cercanas al cero absoluto o soplos destructivos.", weights: { mystoria: 3, ox: 2, kaiser: 2 } },
        { text: "Rosas envenenadas de distintos colores o un ataúd sella-almas.", weights: { cardinale: 3, deathtoll: 3 } },
        { text: "Sabiduría budista, barreras inquebrantables o hipnosis medicinal sagrada.", weights: { shijima: 3, odysseus: 3, dohko: 1 } }
      ]
    }
  ];

  const saintTraits: Record<string, string[]> = {
    shion: ["Muro de Cristal", "Revolución Estelar"],
    ox: ["Gran Cuerno", "Fuerza Devota"],
    cain: ["Explosión Galáctica", "Alma Dual"],
    deathtoll: ["Ataúd Omertà", "Ondas del Inframundo"],
    kaiser: ["Plasma Relámpago", "Leones Guardianes"],
    shijima: ["Cuatro Puertas de Buda", "Doncella Silenciosa"],
    dohko: ["Cien Dragones", "Juventud Impetuosa"],
    ecarlate: ["Aguja Escarlata", "Picadura Invisible"],
    odysseus: ["Cosmos Médico", "Hipnoterapia Divina"],
    gestalt: ["Flecha de Quirón", "Ilusión del Centauro"],
    izo: ["Corte Excalibur", "Filo Recto"],
    mystoria: ["Cero Absoluto", "Ráfaga Glacial"],
    cardinale: ["Rosas Daga", "Belleza Sangrienta"]
  };

  document.addEventListener('DOMContentLoaded', () => {
    const startScreen = document.getElementById('quiz-start-screen');
    const questionScreen = document.getElementById('quiz-question-screen');
    const resultsScreen = document.getElementById('quiz-results-screen');
    
    const startBtn = document.getElementById('start-quiz-btn');
    const restartBtn = document.getElementById('restart-quiz-btn');
    const viewInCodexBtn = document.getElementById('view-in-codex-btn');
    
    const progressContainer = document.getElementById('quiz-progress-bar-container');
    const progressFill = document.getElementById('quiz-progress-fill');
    const counterText = document.getElementById('quiz-counter');
    const questionText = document.getElementById('quiz-question-text');
    const optionsContainer = document.getElementById('quiz-options-container');
    
    const resultName = document.getElementById('result-saint-name');
    const resultTitle = document.getElementById('result-saint-title');
    const resultPortrait = document.getElementById('result-saint-portrait') as HTMLImageElement;
    const resultDesc = document.getElementById('result-saint-desc');
    const trait1 = document.getElementById('trait-1');
    const trait2 = document.getElementById('trait-2');

    let currentQuestionIndex = 0;
    let scores: Record<string, number> = {};
    let winnerId = 'shion';

    function resetQuiz() {
      currentQuestionIndex = 0;
      scores = {
        shion: 0, ox: 0, cain: 0, deathtoll: 0, kaiser: 0,
        shijima: 0, dohko: 0, ecarlate: 0, odysseus: 0, gestalt: 0,
        izo: 0, mystoria: 0, cardinale: 0
      };
      if (progressContainer) {
        progressContainer.setAttribute('aria-valuenow', '0');
      }
    }

    if (startBtn) {
      startBtn.addEventListener('click', () => {
        resetQuiz();
        startScreen?.classList.remove('active');
        questionScreen?.classList.add('active');
        showQuestion();
      });
    }

    if (restartBtn) {
      restartBtn.addEventListener('click', () => {
        resultsScreen?.classList.remove('active');
        startScreen?.classList.add('active');
        setTimeout(() => {
          startBtn?.focus();
        }, 100);
      });
    }

    if (viewInCodexBtn) {
      viewInCodexBtn.addEventListener('click', () => {
        // Scroll to codex
        const codexSec = document.getElementById('codex-section');
        if (codexSec) {
          codexSec.scrollIntoView({ behavior: 'smooth' });
        }
        // Select matching saint
        setTimeout(() => {
          if ((window as any).selectSaintInCodex) {
            (window as any).selectSaintInCodex(winnerId);
          }
        }, 500);
      });
    }

    function showQuestion() {
      const q = quizQuestions[currentQuestionIndex];
      if (!q) {
        calculateAndShowResult();
        return;
      }

      const progress = Math.round((currentQuestionIndex / quizQuestions.length) * 100);
      if (progressFill) {
        progressFill.style.width = `${progress}%`;
      }
      if (progressContainer) {
        progressContainer.setAttribute('aria-valuenow', String(progress));
      }
      
      if (counterText) counterText.textContent = `Pregunta ${currentQuestionIndex + 1} de ${quizQuestions.length}`;
      
      if (questionText) {
        questionText.textContent = q.question;
        // Focus the question text so screen readers announce it immediately on change
        setTimeout(() => {
          questionText.focus();
        }, 50);
      }

      if (optionsContainer) {
        optionsContainer.innerHTML = '';
        q.options.forEach((opt) => {
          const btn = document.createElement('button');
          btn.className = 'option-btn';
          btn.textContent = opt.text;
          
          btn.addEventListener('click', () => {
            btn.classList.add('selected');
            
            Object.keys(opt.weights).forEach(saintId => {
              scores[saintId] = (scores[saintId] || 0) + (opt.weights as any)[saintId];
            });

            // Fade out current question & options
            if (questionText && optionsContainer) {
              questionText.classList.add('fade-out');
              optionsContainer.classList.add('fade-out');
            }

            setTimeout(() => {
              currentQuestionIndex++;
              showQuestion();
              
              // Fade back in
              if (questionText && optionsContainer) {
                questionText.classList.remove('fade-out');
                optionsContainer.classList.remove('fade-out');
              }
            }, 250);
          });

          optionsContainer.appendChild(btn);
        });
      }
    }

    function calculateAndShowResult() {
      if (progressFill) progressFill.style.width = "100%";
      if (progressContainer) progressContainer.setAttribute('aria-valuenow', "100");
      
      let highestScore = -1;

      Object.keys(scores).forEach(id => {
        if (scores[id] > highestScore) {
          highestScore = scores[id];
          winnerId = id;
        }
      });

      const saint = goldSaints.find(s => s.id === winnerId);
      if (!saint) return;

      if (resultName) resultName.textContent = saint.name;
      if (resultTitle) resultTitle.textContent = `Guardián de la ${saint.temple}`;
      if (resultPortrait) {
        resultPortrait.src = saint.image;
        resultPortrait.alt = `Retrato del Caballero de Oro ${saint.name}`;
      }
      if (resultDesc) resultDesc.textContent = `Tu cosmos dimensional está firmemente alineado con ${saint.name}. ${saint.description}`;

      const traits = saintTraits[winnerId] || ["Cosmos Dorado", "Séptimo Sentido"];
      if (trait1) trait1.textContent = traits[0];
      if (trait2) trait2.textContent = traits[1];

      questionScreen?.classList.remove('active');
      resultsScreen?.classList.add('active');

      // Focus the results screen for accessibility announcements
      setTimeout(() => {
        resultsScreen?.focus();
      }, 150);
    }
  });
</script>
