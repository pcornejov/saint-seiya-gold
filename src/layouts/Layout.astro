---
// Layout.astro
import '../styles/global.css';
import CanvasBackground from '../components/CanvasBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Saint Seiya: Caballeros de Oro | Codex y Santuario",
  description = "Explora el cosmos de los 12 Caballeros de Oro de Saint Seiya. Descubre sus técnicas, recorre los templos del Santuario y descubre tu alineación de Cosmos."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Saint Seiya, Caballeros de Oro, Gold Saints, Santuario, Zodiaco, Atena, Cosmos, Seiya" />
    <meta name="author" content="Pablo Cornejo" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/saint-seiya-gold/favicon.svg" />
  </head>
  <body>
    <!-- Skip to main content link for screen readers -->
    <a href="#main-content" class="skip-to-content">Saltar al contenido principal</a>

    <!-- Canvas for interactive cosmic space particle system -->
    <CanvasBackground />

    <!-- Background music (ambient/silent by default) -->
    <audio id="bg-music" loop preload="auto">
      <source src="https://assets.mixkit.co/active_storage/sfx/2568/2568-84.wav" type="audio/wav">
    </audio>

    <!-- Header & Navigation -->
    <header id="site-header">
      <div class="container">
        <a href="#hero-section" class="logo gold-text-gradient">SAINT SEIYA <span>GOLD</span></a>
        
        <button class="menu-toggle" id="mobile-menu-btn" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="nav-menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav>
          <ul class="nav-links" id="nav-menu">
            <li><a href="#hero-section" id="nav-item-home">Inicio</a></li>
            <li><a href="#codex-section" id="nav-item-codex">Caballeros</a></li>
            <li><a href="#sanctuary-section" id="nav-item-sanctuary">El Santuario</a></li>
            <li><a href="#quiz-section" id="nav-item-quiz">Alineación</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Slots render page contents -->
    <slot />

    <!-- Footer -->
    <footer>
      <div class="container footer-content">
        <p>© 2026 Saint Seiya: Gold Knights. Diseñado para fines de demostración por Pablo Cornejo.</p>
        <p class="footer-sub">Los personajes, nombres e imágenes pertenecen a Masami Kurumada / Toei Animation / MyAnimeList.</p>
      </div>
    </footer>

    <!-- Sound Controller Floating Button -->
    <div class="sound-toggle-container">
      <button class="btn-sound" id="music-toggle" aria-label="Activar música de fondo" aria-pressed="false">
        <!-- Speaker Icon -->
        <svg viewBox="0 0 24 24" id="sound-off-icon">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM12 4L9.91 6.09 12 8.18V4zm-8 4v8h4l5 5v-6.18l-5-5H4zm17.65-3.53l-1.41-1.41L2.64 17.65l1.41 1.41 6.13-6.13V20l5-5h3.18l-6.13-6.13 6.13-6.13L21.65 4.47z"/>
        </svg>
        <svg viewBox="0 0 24 24" id="sound-on-icon" class="hide">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
    </div>
  </body>
</html>

<style is:global>
  /* Header specific styles */
  header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--header-height);
    z-index: 100;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  header.scrolled {
    background: rgba(2, 2, 8, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 215, 0, 0.2);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .logo {
    font-family: var(--font-decorative);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 2px;
    display: flex;
    align-items: center;
    gap: 10px;
    text-shadow: 0 2px 10px rgba(255, 215, 0, 0.15);
  }

  .logo span {
    font-size: 1rem;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-weight: 300;
    opacity: 0.8;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    position: relative;
    padding: 0.5rem 0;
    color: var(--text-secondary);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gold-primary);
    box-shadow: var(--gold-glow);
    transition: all 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--gold-primary);
    text-shadow: var(--gold-glow);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-links a.active {
    color: var(--gold-primary);
    text-shadow: var(--gold-glow);
  }

  .nav-links a.active::after {
    width: 100%;
  }

  /* Sound Controller */
  .sound-toggle-container {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 99;
  }

  .btn-sound {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(12, 12, 32, 0.85) 0%, rgba(2, 2, 8, 0.95) 100%);
    border: 1.5px solid var(--gold-secondary);
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--gold-light);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6), inset 0 0 10px rgba(255, 215, 0, 0.05);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    position: relative;
  }

  .btn-sound::before {
    content: '';
    position: absolute;
    top: -4px;
    left: -4px;
    right: -4px;
    bottom: -4px;
    border-radius: 50%;
    border: 1px dashed rgba(255, 215, 0, 0.25);
    animation: rotateWheel 20s infinite linear;
    pointer-events: none;
    transition: all 0.3s ease;
  }

  .btn-sound:hover {
    border-color: var(--gold-primary);
    color: #020208;
    background: var(--gold-cosmic);
    box-shadow: var(--gold-glow-strong), 0 6px 20px rgba(255, 215, 0, 0.2);
    transform: scale(1.1) rotate(15deg);
  }

  .btn-sound:hover::before {
    border-color: var(--gold-primary);
    transform: scale(1.05);
  }

  .btn-sound svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* Footer specific styles */
  footer {
    background: rgba(2, 2, 8, 0.95);
    border-top: 1px solid rgba(255, 215, 0, 0.15);
    padding: 3rem 0;
    text-align: center;
    position: relative;
    z-index: 2;
    color: var(--text-secondary);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .footer-sub {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  /* Responsive Menu */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    cursor: pointer;
  }

  .menu-toggle span {
    display: block;
    width: 25px;
    height: 2px;
    background-color: var(--text-primary);
    transition: all 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(6px, 6px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }
    
    .nav-links {
      position: fixed;
      top: var(--header-height);
      right: -100%;
      width: 250px;
      height: calc(100vh - var(--header-height));
      background: rgba(4, 4, 15, 0.95);
      flex-direction: column;
      padding: 3rem 2rem;
      gap: 2rem;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.4s ease;
      border-left: 1px solid rgba(255, 215, 0, 0.15);
      backdrop-filter: blur(20px);
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
      visibility: hidden; /* Prevent keyboard focus and screen readers from accessing off-screen menu when closed */
    }
    
    .nav-links.active {
      right: 0;
      visibility: visible;
    }
  }
</style>

<script>
  // Navigation scrolling headers & sound toggle
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('site-header');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      });
    }

    // Mobile Menu
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const navMenu = document.getElementById('nav-menu');
    const navLinks = document.querySelectorAll('.nav-links a');

    if (mobileBtn && navMenu) {
      mobileBtn.addEventListener('click', () => {
        const isActive = navMenu.classList.toggle('active');
        mobileBtn.classList.toggle('active');
        mobileBtn.setAttribute('aria-expanded', isActive ? 'true' : 'false');
        if (isActive) {
          // Put focus inside menu or just help screen readers
          navMenu.setAttribute('aria-hidden', 'false');
        } else {
          navMenu.setAttribute('aria-hidden', 'true');
        }
      });

      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          navMenu.classList.remove('active');
          mobileBtn.classList.remove('active');
          mobileBtn.setAttribute('aria-expanded', 'false');
          navMenu.setAttribute('aria-hidden', 'true');
        });
      });
    }

    // Sound Player logic
    const audio = document.getElementById('bg-music') as HTMLAudioElement;
    const soundToggle = document.getElementById('music-toggle');
    const soundOffIcon = document.getElementById('sound-off-icon');
    const soundOnIcon = document.getElementById('sound-on-icon');
    let isMuted = true;
    let audioStarted = false;

    if (audio) {
      audio.volume = 0.2;
    }

    if (soundToggle && audio && soundOffIcon && soundOnIcon) {
      soundToggle.addEventListener('click', () => {
        if (!audioStarted) {
          audio.play().then(() => {
            audioStarted = true;
            isMuted = false;
            updateUI();
          }).catch(err => console.log(err));
        } else {
          if (isMuted) {
            audio.muted = false;
            audio.play();
            isMuted = false;
          } else {
            audio.muted = true;
            isMuted = true;
          }
          updateUI();
        }
      });

      document.body.addEventListener('click', () => {
        if (!audioStarted && isMuted) {
          audio.play().then(() => {
            audioStarted = true;
            audio.muted = true;
            isMuted = true;
            updateUI();
          }).catch(() => {});
        }
      }, { once: true });
    }

    function updateUI() {
      if (isMuted) {
        if (soundOffIcon) soundOffIcon.classList.remove('hide');
        if (soundOnIcon) soundOnIcon.classList.add('hide');
        if (soundToggle) {
          soundToggle.setAttribute('aria-label', 'Activar música de fondo');
          soundToggle.setAttribute('aria-pressed', 'false');
        }
      } else {
        if (soundOffIcon) soundOffIcon.classList.add('hide');
        if (soundOnIcon) soundOnIcon.classList.remove('hide');
        if (soundToggle) {
          soundToggle.setAttribute('aria-label', 'Desactivar música de fondo');
          soundToggle.setAttribute('aria-pressed', 'true');
        }
      }
    }

    // Scrollspy Navigation Highlights
    const sections = document.querySelectorAll('section');
    const navItems = {
      'hero-section': document.getElementById('nav-item-home'),
      'codex-section': document.getElementById('nav-item-codex'),
      'sanctuary-section': document.getElementById('nav-item-sanctuary'),
      'quiz-section': document.getElementById('nav-item-quiz')
    };

    window.addEventListener('scroll', () => {
      let currentSectionId = '';
      
      sections.forEach(section => {
        const sectionTop = section.offsetTop - 150;
        const sectionHeight = section.clientHeight;
        if (window.scrollY >= sectionTop && window.scrollY < sectionTop + sectionHeight) {
          currentSectionId = section.getAttribute('id') || '';
        }
      });

      Object.keys(navItems).forEach(id => {
        const item = navItems[id];
        if (item) {
          if (id === currentSectionId) {
            item.classList.add('active');
            item.setAttribute('aria-current', 'page');
          } else {
            item.classList.remove('active');
            item.removeAttribute('aria-current');
          }
        }
      });
    });
  });
</script>
